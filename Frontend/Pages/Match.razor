@page "/match/{id}"
@using System.Net.Http.Json
@using System.Linq
@using Shared
@inject HttpClient Http
@inject NavigationManager Nav

<h2>Matchinformation</h2>

@if (isLoading)
{
    <p>Laddar matchinformation...</p>
}
else if (match is null)
{
    <p>Matchen hittades inte.</p>
}
else
{
    <h3>@match.GameName</h3>

    <p>
        Match-ID: @match.Id<br />
        Regler: @(match.HighScoreWins ? "Högsta poäng vinner" : "Lägsta poäng vinner")<br />
        Startpoäng: @match.StartScore<br />
        Spelare låsta: @(match.PlayersLocked ? "Ja" : "Nej")<br />
        Skapad: @match.CreatedAt.ToString("g")<br />
    </p>

    <h4>Spelare</h4>

    @if (match.Players.Count == 0)
    {
        <p>Inga spelare än.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Namn</th>
                    <th>Poäng</th>
                    <th>Åtgärder</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var player in SortedPlayers)
                {
                    <tr @key="player.Id">
                        <td>
                            <input value="@player.Name"
                                   @onchange="e => UpdatePlayerName(player, e.Value?.ToString() ?? string.Empty)" />
                        </td>
                        <td>
                            <input type="number"
                                   @bind="player.Score"
                                   @bind:after="async () => await UpdatePlayerScore(player, player.Score.ToString())" />
                        </td>
                        <td>
                            <button type="button" @onclick="() => ChangeScore(player, -1)">-1</button>
                            <button type="button" @onclick="() => ChangeScore(player, -5)">-5</button>
                            <button type="button" @onclick="() => ChangeScore(player, 1)">+1</button>
                            <button type="button" @onclick="() => ChangeScore(player, 5)">+5</button>

                            @if (!match.PlayersLocked)
                            {
                                <button type="button" @onclick="() => RemovePlayer(player)">Ta bort</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!match.PlayersLocked)
    {
        <h4>Lägg till spelare</h4>
        <input @bind="newPlayerName" placeholder="Spelarnamn" />
        <button type="button" @onclick="AddPlayer">Lägg till</button>
    }

    <hr />

    <button type="button" @onclick="ResetMatch">Återställ match</button>
    <button type="button" @onclick="CloneMatch">Klona match</button>
    @* <button type="button" @onclick="DeleteMatch">Ta bort match</button> *@

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p style="color: green;">@statusMessage</p>
    }
}

@if (showErrorPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Fel</h4>
            <p>@errorMessage</p>
            <button type="button" @onclick="CloseErrorPopup">OK</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private GameMatch? match;
    private bool isLoading = true;
    private bool showErrorPopup = false;
    private string errorMessage = string.Empty;
    private string newPlayerName = string.Empty;
    private string statusMessage = string.Empty;

    private IEnumerable<GamePlayer> SortedPlayers =>
        match is null
            ? Enumerable.Empty<GamePlayer>()
            : match.HighScoreWins
                ? match.Players.OrderByDescending(p => p.Score)
                : match.Players.OrderBy(p => p.Score);

    protected override async Task OnInitializedAsync()
    {
        await LoadMatch();
    }

    private void CloseErrorPopup()
    {
        showErrorPopup = false;
        errorMessage = string.Empty;
    }

    private async Task LoadMatch()
    {
        try
        {
            isLoading = true;
            statusMessage = string.Empty;

            match = await Http.GetFromJsonAsync<GameMatch>($"/api/match/{Id}");

            if (match is null)
            {
                ShowError("Matchen kunde inte laddas.");
            }
        }
        catch
        {
            ShowError("Kunde inte hämta matchen.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        showErrorPopup = true;
    }

    private async Task ChangeScore(GamePlayer player, int delta)
    {
        var operation = delta < 0 ? "decrease" : "increase";
        var amount = Math.Abs(delta);
        
        var response = await Http.PutAsync(
            $"/api/match/{Id}/player/{player.Id}/score?amount={amount}&operation={operation}", null);
        
        /*var newScore = player.Score + delta;
        await SetPlayerScore(player, newScore);*/

        if (!response.IsSuccessStatusCode)
        {
            ShowError("Poängen gick inte att ändra");
            return;
        }

        player.Score += delta;
    }

    private async Task UpdatePlayerScore(GamePlayer player, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            ShowError("Ogiltigt poängvärde");
            return;
        }

        value = value.Replace('-', '-'); //extra säkring för MacOS/andra OS
        
        if (int.TryParse(value, out var newScore))
        {
            await SetPlayerScore(player, newScore);
        }
        else
        {
            ShowError("Ogiltigt poängvärde.");
        }
    }

    private async Task SetPlayerScore(GamePlayer player, int newScore)
    {
        var response = await Http.PutAsync($"/api/match/{Id}/player/{player.Id}/score?newScore={newScore}", null);

        if (response.IsSuccessStatusCode)
        {
            player.Score = newScore;
            statusMessage = "Poängen uppdaterades.";
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task UpdatePlayerName(GamePlayer player, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            ShowError("Spelarnamnet får inte vara tomt.");
            return;
        }

        var response = await Http.PutAsync($"/api/match/{Id}/player/{player.Id}/name?newName={Uri.EscapeDataString(newName)}", null);

        if (response.IsSuccessStatusCode)
        {
            player.Name = newName.Trim();
            statusMessage = "Namnet uppdaterades.";
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName))
        {
            ShowError("Ange ett spelarnamn.");
            return;
        }

        var response = await Http.PostAsync($"/api/match/{Id}/player?playerName={Uri.EscapeDataString(newPlayerName)}", null);

        if (response.IsSuccessStatusCode)
        {
            newPlayerName = string.Empty;
            statusMessage = "Spelaren lades till.";
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task RemovePlayer(GamePlayer player)
    {
        var response = await Http.DeleteAsync($"/api/match/{Id}/player/{player.Id}");

        if (response.IsSuccessStatusCode)
        {
            statusMessage = "Spelaren togs bort.";
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task ResetMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/reset", null);

        if (response.IsSuccessStatusCode)
        {
            statusMessage = "Matchen startades om.";
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task CloneMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/clone", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CloneResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                Nav.NavigateTo(result.Url);
            }
            else
            {
                ShowError("Kunde inte öppna den klonade matchen.");
            }
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private class CloneResponse
    {
        public string Id { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }
}