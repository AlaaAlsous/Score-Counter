@page "/match/{id}"
@using System.Linq
@using Shared
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<PageTitle>Match</PageTitle>
<div class="match-container">
    <span class="match-info-label">Matchinformation</span>

@if (_isLoading)
{ <p>Laddar matchinformation...</p>
}
else if (_match is null)
{
    <p>Matchen hittades inte.</p>
}
else
{
    <h3 class="match-title">@_match.GameName</h3>

    @if (_match.IsFinished)
    {
        <p style="color: red; font-weight: bold;">Matchen är avslutad.</p>
    }

    <div class="match-info-box">
        <div class="match-info-row">
            <div class="match-info-item">
                <strong>Match-ID:</strong>
                <span class="match-info-value match-info-id">@_match.Id</span>
                <button type="button" class="copy-link-btn" @onclick="CopyMatchLink">Kopiera länk</button>
            </div>
            <div class="match-info-item"><strong>Regler:</strong> <span class="match-info-value">@(_match.HighScoreWins ? "Högsta poäng vinner" : "Lägsta poäng vinner")</span></div>
        </div>
        <div class="match-info-row">
            <div class="match-info-item"><strong>Startpoäng:</strong> <span class="match-info-value">@_match.StartScore</span></div>
            <div class="match-info-item"><strong>Spelare låsta:</strong> <span class="match-info-value">@(_match.PlayersLocked ? "Ja" : "Nej")</span></div>
            <div class="match-info-item"><strong>Skapad:</strong> <span class="match-info-value">@_match.CreatedAt.ToString("g")</span></div>
        </div>
    </div>

    <form class="match-form" onsubmit="return false">
        <h4>Spelare</h4>

        <p style="margin-bottom: 0.7rem; min-height: 1.5em; color:@StatusMessageColor; visibility: visible;">
            @(string.IsNullOrWhiteSpace(_statusMessage) ? "" : _statusMessage)
        </p>


        @if (_match.Players.Count == 0)
        {
            <p>Inga spelare än.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr class="player-header-row">
                        <th style="grid-column: 1;">Namn &amp; Poäng</th>
                        <th style="grid-column: 2;">Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Players)
                    {
                        <tr @key="player.Id">
                            <td colspan="3" class="player-row">
                                <div class="player-info-row">
                                    <input value="@player.Name"
                                           readonly="@_match.IsFinished"
                                           @onchange="e => UpdatePlayerName(player, e.Value?.ToString() ?? string.Empty)" />
                                    <input type="text"
                                           value="@player.Score"
                                           readonly />
                                </div>
                                <div class="player-actions-row">
                                    @if (!_match.IsFinished)
                                    {
                                        <button type="button" @onclick="() => ChangeScore(player, -1)">-1</button>
                                        <button type="button" @onclick="() => ChangeScore(player, -5)">-5</button>
                                        <button type="button" @onclick="() => ChangeScore(player, 1)">+1</button>
                                        <button type="button" @onclick="() => ChangeScore(player, 5)">+5</button>
                                    }
                                    @if (!_match.PlayersLocked && !_match.IsFinished)
                                    {
                                        <button type="button" class="remove-player-btn" @onclick="() => RemovePlayer(player)">Ta bort</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (!_match.PlayersLocked && !_match.IsFinished)
        {
            <h4>Lägg till spelare</h4>
            <input @bind="_newPlayerName" @onkeyup="HandleKey" placeholder="Spelarnamn" />
            <button type="button" @onclick="AddPlayer">Lägg till</button>
        }

        <hr />

        <div class="match-action-row">
            @if (!_match.IsFinished)
            {
                <button type="button" @onclick="ShowFinishConfirm" class="match-action-btn">Avsluta match</button>
            }
            else
            {
                <button type="button" @onclick="ShowResults" class="match-action-btn">Visa slutresultat</button>
            }

            <button type="button" @onclick="ResetMatch" class="match-action-btn">Återställ match</button>
            <button type="button" @onclick="CloneMatch" class="match-action-btn">Klona match</button>
        </div>
    </form>
}

@if (_showErrorPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Fel</h4>
            <p>@_errorMessage</p>
            <button type="button" @onclick="CloseErrorPopup">OK</button>
        </div>
    </div>
}
</div>

@if (_showFinishConfirmPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Avsluta match</h4>
            <p>Är du säker på att du vill avsluta matchen? Inga ändringar kan göras efter avslutad match.</p>
            <div class="match-action-row">
                <button type="button" class="match-action-btn" @onclick="FinishMatch">Ja, avsluta</button>
                <button type="button" class="match-action-btn" @onclick="CloseFinishConfirm">Nej, tillbaka</button>
            </div>
        </div>
    </div>
}

@if (_showResultsPopup && _match is not null)
{
    <div class="popup-backdrop">
        <div class="popup-box results-popup">
            <h3>Slutresultat</h3>

            <p>
                <strong>Match:</strong> @_match.GameName
            </p>

            @if (SortedPlayers.Any())
            {
                var winner = SortedPlayers.First();

                <div class="winner-box">
                    <h4>Vinnare</h4>
                    <p class="winner-name">@winner.Name</p>
                    <p>@winner.Score poäng</p>
                </div>

                <table class="table">
                    <thead>
                        <tr>
                            <th>Placering</th>
                            <th>Namn</th>
                            <th>Poäng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var placement = 1;
                        }
                        @foreach (var player in SortedPlayers)
                        {
                            <tr>
                                <td>@placement</td>
                                <td>@player.Name</td>
                                <td>@player.Score</td>
                            </tr>
                            placement++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Det finns inga spelare att visa.</p>
            }

            <div class="match-action-row">
                <button type="button" class="match-action-btn" @onclick="CloseResults">Stäng</button>
                <button type="button" class="match-action-btn" @onclick="ResetMatch">Ny match från start</button>
                <button type="button" class="match-action-btn" @onclick="CloneMatch">Klona match</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private GameMatch? _match;
    private bool _isLoading = true;
    private bool _showErrorPopup;
    private bool _showResultsPopup;
    private bool _showFinishConfirmPopup;
    private string _errorMessage = string.Empty;
    private string _newPlayerName = string.Empty;
    private string _statusMessage = string.Empty;

    private HubConnection? _hub;

    private IEnumerable<GamePlayer> Players =>
    _match?.Players ?? Enumerable.Empty<GamePlayer>();

    private IEnumerable<GamePlayer> SortedPlayers =>
    _match is null
        ? Enumerable.Empty<GamePlayer>()
        : _match.HighScoreWins
            ? _match.Players.OrderByDescending(p => p.Score)
            : _match.Players.OrderBy(p => p.Score);

    protected override async Task OnParametersSetAsync()
    {
        if (_hub is not null)
        {
            await _hub.SendAsync("LeaveMatch", Id);
            await _hub.DisposeAsync();
        }

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/matchevents"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid, int>("ScoreChanged", (playerId, newScore) =>
        {
            var player = _match?.Players.FirstOrDefault(p => p.Id == playerId);
            if (player is not null)
            {
                player.Score = newScore;
                InvokeAsync(StateHasChanged);
            }
        });

        _hub.On<Guid, string>("PlayerRenamed", (playerId, newName) =>
        {
            var player = _match?.Players.FirstOrDefault(p => p.Id == playerId);
            if (player is not null)
            {
                player.Name = newName;
                InvokeAsync(StateHasChanged);
            }
        });

        _hub.On<GamePlayer>("PlayerAdded", _ =>
            InvokeAsync(LoadMatch));

        _hub.On<string>("PlayerRemoved", _ =>
            InvokeAsync(LoadMatch));

        _hub.On("MatchFinished", () =>
            InvokeAsync(LoadMatch));

        _hub.On<string>("MatchReset", newUrl =>
            InvokeAsync(() => Nav.NavigateTo(newUrl)));

        await _hub.StartAsync();
        await _hub.SendAsync("JoinMatch", Id);
        await LoadMatch();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.SendAsync("LeaveMatch", Id);
            await _hub.DisposeAsync();
        }
    }

    private void CloseErrorPopup()
    {
        _showErrorPopup = false;
        _errorMessage = string.Empty;
    }

    private async Task LoadMatch()
    {
        try
        {
            _isLoading = true;
            _showErrorPopup = false;
            _errorMessage = string.Empty;
            _showResultsPopup = false;
            _showFinishConfirmPopup = false;

            _match = await Http.GetFromJsonAsync<GameMatch>($"/api/match/{Id}");

            if (_match is null)
            {
                ShowError("Matchen kunde inte laddas.");
            }
        }
        catch
        {
            ShowError("Kunde inte hämta matchen.");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged(); 
        }
    }

    private void ShowError(string message)
    {
        _errorMessage = message;
        _showErrorPopup = true;
    }

    private async Task ChangeScore(GamePlayer player, int delta)
    {
        var operation = delta < 0 ? "decrease" : "increase";
        var amount = Math.Abs(delta);

        var response = await Http.PutAsync(
            $"/api/match/{Id}/player/{player.Id}/score?amount={amount}&operation={operation}", null);

        if (!response.IsSuccessStatusCode)
        {
            ShowError("Poängen gick inte att ändra");
            return;
        }

        _statusMessage = $@"{player.Name}: Poängen uppdaterades.";
        StateHasChanged();

        _ = HideStatusMessage();
    }

    private void ShowResults()
    {
        _showResultsPopup = true;
    }

    private void CloseResults()
    {
        _showResultsPopup = false;
    }

    private void ShowFinishConfirm()
    {
        _showFinishConfirmPopup = true;
    }

    private void CloseFinishConfirm()
    {
        _showFinishConfirmPopup = false;
    }

    private async Task FinishMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/finish", null);

        if (response.IsSuccessStatusCode)
        {
            _showFinishConfirmPopup = false;
            await LoadMatch();
            ShowResults();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task UpdatePlayerName(GamePlayer player, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            ShowError("Spelarnamnet får inte vara tomt.");
            return;
        }

        var response = await Http.PutAsync($"/api/match/{Id}/player/{player.Id}/name?newName={Uri.EscapeDataString(newName)}", null);

        if (response.IsSuccessStatusCode)
        {
            player.Name = newName.Trim();
            _statusMessage = $@"{player.Name}: Namnet uppdaterades.";
            _ = HideStatusMessage();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(_newPlayerName))
        {
            ShowError("Ange ett spelarnamn.");
            return;
        }

        var addedName = _newPlayerName.Trim();
        var response = await Http.PostAsync($"/api/match/{Id}/player?playerName={Uri.EscapeDataString(_newPlayerName)}", null);

        if (response.IsSuccessStatusCode)
        {
            _statusMessage = $@"{addedName}: Spelaren lades till.";
            _newPlayerName = string.Empty;
            _ = HideStatusMessage();
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task RemovePlayer(GamePlayer player)
    {
        var response = await Http.DeleteAsync($"/api/match/{Id}/player/{player.Id}");

        if (response.IsSuccessStatusCode)
        {
            var removedName = player.Name;
            _statusMessage = $@"{removedName}: Spelaren togs bort.";
            _ = HideStatusMessage();
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task ResetMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/reset", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CloneResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                Nav.NavigateTo(result.Url);
            }
            else
            {
                ShowError("Kunde inte skapa en återställd match.");
            }
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task CloneMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/clone", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CloneResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                Nav.NavigateTo(result.Url);
            }
            else
            {
                ShowError("Kunde inte öppna den klonade matchen.");
            }
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddPlayer();
        }
    }

    private async Task HideStatusMessage()
    {
        await Task.Delay(2000);
        _statusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private class CloneResponse
    {
        public string Id { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }

    private async Task CopyMatchLink()
    {
        try
        {
            var absoluteUrl = Nav.ToAbsoluteUri($"/match/{Id}").ToString();
            var success = await JS.InvokeAsync<bool>("copyToClipboard", absoluteUrl);

            if (success)
            {
                _statusMessage = "Match Länken kopierades.";
                _ = HideStatusMessage();
            }
            else
            {
                ShowError("Kunde inte kopiera länken.");
            }
        }
        catch
        {
            ShowError("Kunde inte kopiera länken.");
        }
    }
        private string StatusMessageColor
    {
        get
        {
            if (_statusMessage.Contains("togs bort"))
                return "red";
            if (_statusMessage.Contains("lades till"))
                return "green";
            if (_statusMessage.Contains("kopierades"))
                return "orange";
            if (_statusMessage.Contains("Namnet uppdaterades"))
                return "blue";
            if (_statusMessage.Contains("Poängen uppdaterades"))
                return "purple";
            return "#1f1f1f"; 
        }
    }
}
