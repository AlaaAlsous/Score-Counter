@page "/match/{id}"
@using System.Linq
@using Shared
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<PageTitle>Match</PageTitle>

@if (_isLoading)
{
    <div class="loading-spinner-container">
        <div class="loading-spinner"></div>
        <p>Loading match info...</p>
    </div>
}
else if (_match is null)
{
    <div class="alert alert-danger">Match not found.</div>
}
else
{
    <div class="match-page">
        <div class="match-header">
            <h2>@_match.GameName</h2>
            @if (_match.IsFinished)
            {
                <span class="badge badge-finished">Finished</span>
            }
            else if (_match.PlayersLocked)
            {
                <span class="badge badge-locked">Players Locked</span>
            }
        </div>

        <div class="card" style="margin-bottom: 1.25rem;">
            <div class="card-body">
                <div class="match-info-content">
                    <div class="match-info-item">
                        <strong>Match ID:</strong>
                        <span class="match-id">@_match.Id</span>
                        <button type="button" class="copy-link-btn" @onclick="CopyMatchLink">📋 Copy Link</button>
                    </div>
                    <div class="match-info-item">
                        <strong>Rules:</strong>
                        @(_match.HighScoreWins ? "Highest score wins" : "Lowest score wins")
                    </div>
                    <div class="match-info-item">
                        <strong>Starting Score:</strong> @_match.StartScore
                    </div>
                    <div class="match-info-item">
                        <strong>Created:</strong> @_match.CreatedAt.ToString("g")
                    </div>
                </div>
            </div>
        </div>

        <div class="status-bar" style="background: @StatusBarBg; color: @StatusBarColor;">
            @(string.IsNullOrWhiteSpace(_statusMessage) ? "" : _statusMessage)
        </div>

        <div class="section-title">Players</div>

        @if (_match.Players.Count == 0)
        {
            <div class="card" style="margin-bottom: 1.5rem;">
                <div class="empty-state">
                    <div class="icon">👥</div>
                    <p>No players yet.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card table-card">
                <table>
                    <thead>
                        <tr>
                            <th>Player</th>
                            <th>Score</th>
                            <th>Score Change</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in Players)
                        {
                            <tr @key="player.Id">
                                <td>
                                    <input value="@(_editingPlayerId == player.Id ? _editingName : player.Name)"
                                           readonly="@_match.IsFinished"
                                           class="player-name-input"
                                           @oninput="e => StartEditName(player, e.Value?.ToString() ?? string.Empty)"
                                           @onchange="e => ConfirmEditName(player)" />
                                </td>
                                <td><span class="score-display">@player.Score</span></td>
                                <td>
                                    @if (!_match.IsFinished)
                                    {
                                        <div class="score-actions">
                                            <button class="score-btn score-btn-minus" @onclick="() => ChangeScore(player, -1)">-1</button>
                                            <button class="score-btn score-btn-minus" @onclick="() => ChangeScore(player, -5)">-5</button>
                                            <button class="score-btn score-btn-plus" @onclick="() => ChangeScore(player, 1)">+1</button>
                                            <button class="score-btn score-btn-plus" @onclick="() => ChangeScore(player, 5)">+5</button>
                                            <span class="custom-score-group">
                                                <input type="number"
                                                       class="custom-score-input"
                                                       value="@GetCustomAmount(player.Id)"
                                                       @oninput="e => SetCustomAmount(player.Id, e.Value?.ToString())"
                                                       placeholder="?"
                                                       min="0" />
                                                <button class="score-btn score-btn-minus" @onclick="() => HandleCustomScore(player, false)">-</button>
                                                <button class="score-btn score-btn-plus" @onclick="() => HandleCustomScore(player, true)">+</button>
                                            </span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (!_match.PlayersLocked && !_match.IsFinished)
                                    {
                                        <button type="button" class="remove-btn" @onclick="() => ShowRemoveConfirm(player)" title="Remove player">✕</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (_scoreHistory.Count > 0)
        {
            <div class="section-title">Score History</div>
            <div class="history-by-player">
                @foreach (var group in HistoryByPlayer)
                {
                    <div class="card player-history-card">
                        <div class="player-history-header">
                            <span class="player-history-name">@group.Key</span>
                            <span class="player-history-current">Current: @group.First().ScoreAfter</span>
                        </div>
                        <table class="player-history-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Change</th>
                                    <th>Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in group)
                                {
                                    <tr class="@(entry.Delta > 0 ? "history-plus" : "history-minus")">
                                        <td class="history-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                        <td class="history-delta">@(entry.Delta > 0 ? "+" : "")@entry.Delta</td>
                                        <td class="history-score">@entry.ScoreBefore → @entry.ScoreAfter</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @if (!_match.PlayersLocked && !_match.IsFinished)
        {
            <div class="card add-player-card">
                <div class="card-body">
                    <div class="section-title" style="margin-bottom: 0.75rem;">Add Player</div>
                    <div class="add-player-row">
                        <input class="form-input" @bind="_newPlayerName" @onkeyup="HandleKey" placeholder="Player name" />
                        <button type="button" class="btn btn-primary" @onclick="AddPlayer">Add</button>
                    </div>
                </div>
            </div>
        }

        <div class="actions-row">
            @if (!_match.IsFinished)
            {
                <button type="button" class="btn btn-danger" @onclick="ShowFinishConfirm">🏁 End Match</button>
            }
            else
            {
                <button type="button" class="btn btn-primary" @onclick="ShowResults">🏆 Show Results</button>
            }

            <button type="button" class="btn btn-outline" @onclick="ResetMatch">🔄 Reset Match</button>
            <button type="button" class="btn btn-outline" @onclick="CloneMatch">📋 Clone Match</button>
        </div>
    </div>
}

@if (_showErrorPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Error</h4>
            <p>@_errorMessage</p>
            <button type="button" class="btn btn-primary" @onclick="CloseErrorPopup">OK</button>
        </div>
    </div>
}

@if (_showFinishConfirmPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>End Match</h4>
            <p>Are you sure you want to end the match? No changes can be made after the match is ended.</p>
            <div class="actions-row">
                <button type="button" class="btn btn-danger" @onclick="FinishMatch">Yes, end</button>
                <button type="button" class="btn btn-outline" @onclick="CloseFinishConfirm">No, go back</button>
            </div>
        </div>
    </div>
}

@if (_showRemoveConfirmPopup && _playerToRemove is not null)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Remove Player</h4>
            <p>Are you sure you want to remove <strong>@_playerToRemove.Name</strong>? This will also delete all their score history.</p>
            <div class="actions-row">
                <button type="button" class="btn btn-danger" @onclick="ConfirmRemovePlayer">Yes, remove</button>
                <button type="button" class="btn btn-outline" @onclick="CloseRemoveConfirm">No, go back</button>
            </div>
        </div>
    </div>
}

@if (_showResultsPopup && _match is not null)
{
    <div class="popup-backdrop">
        <div class="popup-box results-popup" style="max-width: 560px;">
            <h3>🏆 Final Results</h3>

            <p><strong>Match:</strong> @_match.GameName</p>

            @if (SortedPlayers.Any())
            {
                var winner = SortedPlayers.First();

                <div class="winner-box">
                    <h4>Winner</h4>
                    <p class="winner-name">@winner.Name</p>
                    <p>@winner.Score points</p>
                </div>

                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var placement = 1;
                        }
                        @foreach (var player in SortedPlayers)
                        {
                            <tr>
                                <td>@placement</td>
                                <td>@player.Name</td>
                                <td style="text-align: center; font-weight: 700;">@player.Score</td>
                            </tr>
                            placement++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>There are no players to display.</p>
            }

            <div class="actions-row" style="margin-top: 1.5rem;">
                <button type="button" class="btn btn-outline" @onclick="CloseResults">Close</button>
                <button type="button" class="btn btn-outline" @onclick="ResetMatch">🔄 New Match from Start</button>
                <button type="button" class="btn btn-outline" @onclick="CloneMatch">📋 Clone Match</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private GameMatch? _match;
    private bool _isLoading = true;
    private bool _showErrorPopup;
    private bool _showResultsPopup;
    private bool _showFinishConfirmPopup;
    private string _errorMessage = string.Empty;
    private string _newPlayerName = string.Empty;
    private string _statusMessage = string.Empty;
    private bool _showRemoveConfirmPopup;
    private GamePlayer? _playerToRemove;
    private Dictionary<Guid, int> _customScoreAmounts = new();
    private List<ScoreEntry> _scoreHistory = new();

    private IEnumerable<IGrouping<string, ScoreEntry>> HistoryByPlayer =>
        _scoreHistory
            .GroupBy(e => e.PlayerName)
            .OrderBy(g => g.Key);

    private int? GetCustomAmount(Guid playerId) =>
        _customScoreAmounts.TryGetValue(playerId, out var val) ? val : null;

    private void SetCustomAmount(Guid playerId, string? value)
    {
        if (int.TryParse(value, out var parsed) && parsed >= 1)
            _customScoreAmounts[playerId] = parsed;
        else if (string.IsNullOrWhiteSpace(value))
            _customScoreAmounts.Remove(playerId);
    }

    private void HandleCustomScore(GamePlayer player, bool increase)
    {
        var amount = GetCustomAmount(player.Id);
        if (amount is null)
        {
            ShowError("Enter a custom score amount first.");
            return;
        }

        var delta = increase ? amount.Value : -amount.Value;
        _ = ChangeScore(player, delta);
    }

    private HubConnection? _hub;
    private string _currentHubMatchId = string.Empty;
    private readonly SemaphoreSlim _scoreLock = new(1, 1);

    private IEnumerable<GamePlayer> Players =>
        _match?.Players ?? Enumerable.Empty<GamePlayer>();

    private IEnumerable<GamePlayer> SortedPlayers =>
        _match is null
            ? Enumerable.Empty<GamePlayer>()
            : _match.HighScoreWins
                ? _match.Players.OrderByDescending(p => p.Score)
                : _match.Players.OrderBy(p => p.Score);

    private void RegisterHubHandlers()
    {
        if (_hub is null) return;

        _hub.On<Guid, int>("ScoreChanged", (playerId, newScore) =>
        {
            var player = _match?.Players.FirstOrDefault(p => p.Id == playerId);
            if (player is not null)
            {
                player.Score = newScore;
                _statusMessage = $"{player.Name}: Score updated.";
                _ = HideStatusMessage();
                InvokeAsync(StateHasChanged);
            }
        });

        _hub.On<Guid, string>("PlayerRenamed", (playerId, newName) =>
        {
            var player = _match?.Players.FirstOrDefault(p => p.Id == playerId);
            if (player is not null)
            {
                player.Name = newName;
                InvokeAsync(StateHasChanged);
            }
        });

        _hub.On<Guid, string>("ScoreHistoryRenamed", (playerId, newName) =>
        {
            foreach (var entry in _scoreHistory.Where(e => e.PlayerId == playerId))
                entry.PlayerName = newName;
            InvokeAsync(StateHasChanged);
        });

        _hub.On<GamePlayer>("PlayerAdded", _ =>
            InvokeAsync(LoadMatch));

        _hub.On<string>("PlayerRemoved", _ =>
            InvokeAsync(LoadMatch));

        _hub.On("MatchFinished", () =>
            InvokeAsync(LoadMatch));

        _hub.On<string>("MatchReset", newUrl =>
            InvokeAsync(() => Nav.NavigateTo(newUrl)));

        _hub.On<ScoreEntry>("ScoreHistoryEntry", entry =>
        {
            _scoreHistory.Insert(0, entry);
            InvokeAsync(StateHasChanged);
        });

        _hub.On<string>("PlayerHistoryRemoved", playerName =>
        {
            _scoreHistory.RemoveAll(e => e.PlayerName == playerName);
            InvokeAsync(StateHasChanged);
        });
    }

    protected override async Task OnInitializedAsync()
    {
        await ConnectAndJoin();
        await LoadMatch();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _currentHubMatchId)
        {
            await ConnectAndJoin();
            await LoadMatch();
        }
    }

    private async Task ConnectAndJoin()
    {
        if (_hub is not null)
        {
            try
            {
                if (!string.IsNullOrWhiteSpace(_currentHubMatchId) && _hub.State == HubConnectionState.Connected)
                {
                    await _hub.SendAsync("LeaveMatch", _currentHubMatchId);
                }
            }
            catch { }
            await _hub.DisposeAsync();
        }

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/matchevents"))
            .WithAutomaticReconnect()
            .Build();

        RegisterHubHandlers();

        await _hub.StartAsync();
        await _hub.SendAsync("JoinMatch", Id);
        _currentHubMatchId = Id;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try
            {
                if (!string.IsNullOrWhiteSpace(_currentHubMatchId) && _hub.State == HubConnectionState.Connected)
                {
                    await _hub.SendAsync("LeaveMatch", _currentHubMatchId);
                }
            }
            catch { }
            await _hub.DisposeAsync();
        }

        _scoreLock.Dispose();
    }

    private void CloseErrorPopup()
    {
        _showErrorPopup = false;
        _errorMessage = string.Empty;
    }

    private async Task LoadMatch()
    {
        try
        {
            _isLoading = true;
            _showErrorPopup = false;
            _errorMessage = string.Empty;
            _showResultsPopup = false;
            _showFinishConfirmPopup = false;

            _match = await Http.GetFromJsonAsync<GameMatch>($"/api/match/{Id}");
            _scoreHistory = await Http.GetFromJsonAsync<List<ScoreEntry>>($"/api/match/{Id}/history") ?? new();

            if (_match is null)
            {
                ShowError("Could not load the match.");
            }
        }
        catch
        {
            ShowError("Could not fetch the match.");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowError(string message)
    {
        _errorMessage = message;
        _showErrorPopup = true;
    }

    private async Task ChangeScore(GamePlayer player, int delta)
    {
        await _scoreLock.WaitAsync();
        try
        {
            var operation = delta < 0 ? "decrease" : "increase";
            var amount = Math.Abs(delta);
            var originalScore = player.Score;

            player.Score += delta;
            _statusMessage = $"{player.Name}: {delta:+#;-#} ({player.Score})";
            _ = HideStatusMessage();
            StateHasChanged();

            var response = await Http.PutAsync(
                $"/api/match/{Id}/player/{player.Id}/score?amount={amount}&operation={operation}", null);

            if (!response.IsSuccessStatusCode)
            {
                player.Score = originalScore;
                _statusMessage = string.Empty;
                ShowError(await response.Content.ReadAsStringAsync());
                StateHasChanged();
                return;
            }

            if (_customScoreAmounts.Remove(player.Id))
            {
                StateHasChanged();
            }
        }
        finally
        {
            _scoreLock.Release();
        }
    }

    private void ShowResults()
    {
        _showResultsPopup = true;
    }

    private void CloseResults()
    {
        _showResultsPopup = false;
    }

    private void ShowFinishConfirm()
    {
        _showFinishConfirmPopup = true;
    }

    private void CloseFinishConfirm()
    {
        _showFinishConfirmPopup = false;
    }

    private async Task FinishMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/finish", null);

        if (response.IsSuccessStatusCode)
        {
            _showFinishConfirmPopup = false;
            await LoadMatch();
            ShowResults();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private Guid? _editingPlayerId = null;
    private string _editingName = string.Empty;

    private void StartEditName(GamePlayer player, string value)
    {
        _editingPlayerId = player.Id;
        _editingName = value;
    }

    private async Task ConfirmEditName(GamePlayer player)
    {
        var newName = _editingName;
        var originalName = player.Name;
        if (string.IsNullOrWhiteSpace(newName))
        {
            ShowError("Player name cannot be empty.");
            _editingName = originalName;
            StateHasChanged();
            return;
        }

        var response = await Http.PutAsync($"/api/match/{Id}/player/{player.Id}/name?newName={Uri.EscapeDataString(newName)}", null);
        if (response.IsSuccessStatusCode)
        {
            player.Name = newName.Trim();
            _statusMessage = $"{player.Name}: Name updated.";
            _editingPlayerId = null;
            _editingName = string.Empty;
            _ = HideStatusMessage();
        }
        else
        {
            _editingName = originalName;
            ShowError(await response.Content.ReadAsStringAsync());
            StateHasChanged();
        }
    }

    private async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(_newPlayerName))
        {
            ShowError("Enter a player name.");
            return;
        }

        var addedName = _newPlayerName.Trim();
        var response = await Http.PostAsync($"/api/match/{Id}/player?playerName={Uri.EscapeDataString(_newPlayerName)}", null);

        if (response.IsSuccessStatusCode)
        {
            _statusMessage = $"{addedName}: Player added.";
            _newPlayerName = string.Empty;
            _ = HideStatusMessage();
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private void ShowRemoveConfirm(GamePlayer player)
    {
        _playerToRemove = player;
        _showRemoveConfirmPopup = true;
    }

    private void CloseRemoveConfirm()
    {
        _showRemoveConfirmPopup = false;
        _playerToRemove = null;
    }

    private async Task ConfirmRemovePlayer()
    {
        if (_playerToRemove is null) return;
        var player = _playerToRemove;
        _showRemoveConfirmPopup = false;
        _playerToRemove = null;

        var response = await Http.DeleteAsync($"/api/match/{Id}/player/{player.Id}");

        if (response.IsSuccessStatusCode)
        {
            _statusMessage = $"{player.Name}: Player removed.";
            _ = HideStatusMessage();
            await LoadMatch();
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task ResetMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/reset", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CloneResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                Nav.NavigateTo(result.Url);
            }
            else
            {
                ShowError("Could not create a reset match.");
            }
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task CloneMatch()
    {
        var response = await Http.PostAsync($"/api/match/{Id}/clone", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CloneResponse>();

            if (result is not null && !string.IsNullOrWhiteSpace(result.Url))
            {
                Nav.NavigateTo(result.Url);
            }
            else
            {
                ShowError("Could not open the cloned match.");
            }
        }
        else
        {
            ShowError(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddPlayer();
        }
    }

    private async Task HideStatusMessage()
    {
        await Task.Delay(2000);
        _statusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private class CloneResponse
    {
        public string Id { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }

    private async Task CopyMatchLink()
    {
        try
        {
            var absoluteUrl = Nav.ToAbsoluteUri($"/match/{Id}").ToString();
            var success = await JS.InvokeAsync<bool>("copyToClipboard", absoluteUrl);

            if (success)
            {
                _statusMessage = "Match link copied.";
                _ = HideStatusMessage();
            }
            else
            {
                ShowError("Could not copy the link.");
            }
        }
        catch
        {
            ShowError("Could not copy the link.");
        }
    }

    private string StatusBarColor => _statusMessage switch
    {
        var m when m.Contains("removed") => "#991b1b",
        var m when m.Contains("added") => "#065f46",
        var m when m.Contains("copied") => "#92400e",
        var m when m.Contains("Name updated") => "#3730a3",
        var m when m.Contains("Score updated") => "#6b21a8",
        _ => "var(--dark)"
    };

    private string StatusBarBg => _statusMessage switch
    {
        var m when m.Contains("removed") => "var(--danger-bg)",
        var m when m.Contains("added") => "var(--success-bg)",
        var m when m.Contains("copied") => "#fef3c7",
        var m when m.Contains("Name updated") => "var(--primary-light)",
        var m when m.Contains("Score updated") => "#f3e8ff",
        _ => "transparent"
    };
}