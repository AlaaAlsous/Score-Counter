@page "/match/{id}"
@using System.Net.Http.Json
@using Backend.Models
@inject HttpClient Http
@inject NavigationManager Nav

<h2>Matchinformation</h2>

@if (isLoading)
{
    <p>Laddar matchinformation...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color: red;">@errorMessage</p>
}
else if (match is null)
{
    <p>Matchen hittades inte.</p>
}
else
{
    <h3>@match.GameName</h3>>

    <p>
        Match-ID: @match.Id<br />
        Regler: @(match.HighScoreWins ? "Högsta poäng vinner" : "Lägsta poäng vinner")<br />
        Startpoäng: @match.StartScore<br />
        Spelare låsta: @(match.PlayersLocked ? "Ja" : "Nej")<br />
        Skapad: @match.CreatedAt.ToString("g")<br />
}