@page "/createGame"

<PageTitle>Skapa match</PageTitle>

<h1>Mitt spel</h1>

<div class="create-game-container">
    <label>Namn på spel</label>
    <input class="game-name" 
           @bind="_gameName" 
           placeholder="Skriv in namnet på din sport/ditt spel här" />
    
    <label>Startpoäng för spelare</label>
    <input class="starting-points" 
           @bind="_startScore" />
    
    <label>Vad är målet för spelet?</label>
    <select class="order-by-points" @bind="_highScoreWins">
        <option value="max">Få så många poäng som möjligt</option>
        <option value="min">Få så några poäng som möjligt</option>
    </select>
    
    <label>Max antal spelare</label>
    <input
        class="max-players"
        @bind="_maxPlayers"/>
    
    @if (_playerNames.Count >= _maxPlayers)
    {
        <p>Max antal spelare är tillagda!</p>
    }
    
    <label>Lägg till spelare</label>
    <input class="player"
           @bind="_player"
           @onkeyup="HandleKey"
           disabled="@(_playerNames.Count >= _maxPlayers)"/>
    <button
        class="add-player-button"
        @onclick="AddPlayer"
        disabled="@(_playerNames.Count >= _maxPlayers)">Lägg till</button>
    
    <ul>
        @foreach (var name in _playerNames)
        {
            <li>@name</li>
        }
    </ul>
</div>

<button class="create-game-button" @onclick="CreateNewGame">Skapa match</button>

@code {

    string _gameName = "";
    int _startScore;
    string _highScoreWins = "max"; //sätter default till "max"
    string _player = "";
    readonly List<string> _playerNames = [];
    int _maxPlayers = 4;
    
    void AddPlayer()
    {
        if (_playerNames.Count >= _maxPlayers)
        {
            return;
        }
        if (!string.IsNullOrWhiteSpace(_player))
        {
            _playerNames.Add(_player);
            _player = "";
        }
    }
    
    void CreateNewGame()
    {
        //TODO: Skriv logik för att skapa ny match
        
        //Nav.NavigateTo(url) --navigera till den url som skapats
    }

    void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddPlayer();
        }
    }
}
