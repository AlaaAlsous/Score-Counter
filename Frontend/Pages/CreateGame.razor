@page "/"
@using Shared
@inject HttpClient Http
@inject NavigationManager NavManager

    <PageTitle>Create Match</PageTitle>

<div class="card create-game-card">
    <div class="card-header">
        <h3>🎯 Create New Match</h3>
    </div>
    <div class="card-body">
        <div class="create-game-form">
            <label for="gameName">Game Name</label>
            <input id="gameName" class="form-input" @bind="_gameName" placeholder="E.g. Yahtzee, Billiards, Card Game..." />

            <label for="startScore">Starting Score</label>
            <input id="startScore" class="form-input" type="number" @bind="_startScore" />

            <label for="orderByPoints">What is the goal of the game?</label>
            <select id="orderByPoints" class="form-select" value="@_highScoreWins.ToString().ToLower()"
                    @onchange="e => _highScoreWins = bool.TryParse(e.Value?.ToString(), out var val) && val">
                <option value="true">Get as many points as possible</option>
                <option value="false">Get as few points as possible</option>
            </select>

            <label for="maxPlayers">Max Players</label>
            <input id="maxPlayers" class="form-input" type="number" 
                   @bind="MaxPlayers" min="1" />

            @if (_playerNames.Count >= _maxPlayers && _maxPlayers > 0)
            {
                <div class="alert alert-danger">Maximum number of players reached!</div>
            }

            <label for="player">Add Player</label>
            <div style="display: flex; gap: 0.5rem;">
                <input id="player" class="form-input" @bind="_player" @onkeyup="HandleKey"
                       placeholder="Player name"
                       disabled="@(_playerNames.Count >= _maxPlayers && _maxPlayers > 0)" />
                <button type="button" class="btn btn-primary"
                        @onclick="AddPlayer"
                        disabled="@(_playerNames.Count >= _maxPlayers && _maxPlayers > 0)">
                    Add
                </button>
            </div>

            @if (_playerNames.Count > 0)
            {
                <ul class="player-list">
                    @foreach (var name in _playerNames)
                    {
                        <li>@name</li>
                    }
                </ul>
            }

            <label class="checkbox-label">
                <input type="checkbox" @bind="_playersLocked" disabled="@(_playerNames.Count <= 0)" />
                Lock the ability to add more players once the match has started
            </label>

            <button type="submit" class="btn btn-primary" @onclick="CreateNewGame">
                <span>Create Match</span>
            </button>
        </div>
    </div>
</div>

@if (_showErrorPopup)
{
    <div class="popup-backdrop">
        <div class="popup-box">
            <h4>Error</h4>
            <p>@_errorMessage</p>
            <button type="button" class="btn btn-primary" @onclick="CloseErrorPopup">OK</button>
        </div>
    </div>
}

@code {

    string _gameName = "";
    int _startScore;
    bool _highScoreWins = true;
    string _player = "";
    readonly List<string> _playerNames = [];
    int _maxPlayers = 4;
    bool _playersLocked;
    private bool _showErrorPopup = false;
    private string _errorMessage = string.Empty;

    private int MaxPlayers
    {
        get => _maxPlayers;
        set
        {
            var minimum = Math.Max(1, _playerNames.Count);
            if (value < minimum)
            {
                _maxPlayers = minimum;
                ShowError($"Cannot set Max Players below {minimum}. You already have {_playerNames.Count} player(s) added.");
            }
            else
            {
                _maxPlayers = value;
            }
        }
    }

    void AddPlayer()
    {
        if (_playerNames.Count >= _maxPlayers && _maxPlayers > 0)
        {
            return;
        }

        if (_playerNames.Contains(_player))
        {
            ShowError("Player already exists. Enter a different player name.");
            return;
        }

        if (string.IsNullOrWhiteSpace((_player)))
        {
            ShowError("Enter a player name");
            return;
        }

        _playerNames.Add(_player);
        _player = "";
    }

    private void ShowError(string message)
    {
        _errorMessage = message;
        _showErrorPopup = true;
    }

    private void CloseErrorPopup()
    {
        _showErrorPopup = false;
        _errorMessage = string.Empty;
    }

    async Task CreateNewGame()
    {
        if (string.IsNullOrWhiteSpace(_gameName))
        {
            ShowError("Enter a name for your game");
            return;
        }

        if (_playerNames.Count > _maxPlayers && _maxPlayers > 0)
        {
            ShowError($"Max Players ({_maxPlayers}) is less than the number of players added ({_playerNames.Count}). Increase Max Players or remove players.");
            return;
        }

        var game = new MatchRequestDto
        {
            GameName = _gameName,
            HighScoreWins = _highScoreWins,
            MaxPlayers = _maxPlayers,
            PlayersLocked = _playersLocked,
            StartScore = _startScore,
            PlayerNames = _playerNames
        };

        var response = await Http.PostAsJsonAsync("api/match", game);

        if (response.IsSuccessStatusCode)
        {
            var createdGame = await response.Content.ReadFromJsonAsync<MatchResponseDto>();

            if (createdGame != null)
            {
                NavManager.NavigateTo(createdGame.Url);
            }
            else
            {
                NavManager.NavigateTo("/");
            }
        }
    }

    void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddPlayer();
        }
    }
}