@page "/match-enter"
@inject NavigationManager NavManager

    <PageTitle>Go to Match</PageTitle>

<div class="card match-enter-card">
    <div class="card-header">
        <h3>🎮 Go to Match</h3>
    </div>
    <div class="card-body">
        <label for="matchId">Match ID</label>
        <input id="matchId" class="form-input" @bind="_matchId" @onkeyup="HandleKey"
               placeholder="Enter match ID (e.g. AbC123)" />

        <button class="btn btn-primary" @onclick="GoToMatch">Go to Match</button>

        @if (_showError)
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }
    </div>
</div>

@code {
    private string _matchId = string.Empty;
    private bool _showError;
    private string _errorMessage = string.Empty;

    private void GoToMatch()
    {
        if (string.IsNullOrWhiteSpace(_matchId))
        {
            _showError = true;
            _errorMessage = "Enter a match ID.";
            return;
        }

        NavManager.NavigateTo($"/match/{_matchId.Trim()}");
    }

    private void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GoToMatch();
        }
    }
}