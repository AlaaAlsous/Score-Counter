@page "/match-enter"
@inject NavigationManager NavManager

<div class="match-enter-container">
    <h3>Gå till match</h3>
    <label for="matchInput">Ange match-id eller länk:</label>
    <input id="matchInput" @bind="matchInput" @onkeydown="HandleMatchInputKey" autofocus />
    <button @onclick="GoToMatch">Gå till match</button>
    @if (!string.IsNullOrEmpty(matchError))
    {
        <div class="match-dialog-error">@matchError</div>
    }
</div>

@code {
    private string matchInput = string.Empty;
    private string matchError = string.Empty;

    private void GoToMatch()
    {
        var trimmed = matchInput.Trim();
        if (string.IsNullOrEmpty(trimmed))
        {
            matchError = "Du måste ange ett match-id eller länk.";
            return;
        }

        string? id = null;
        if (trimmed.StartsWith("/match/"))
            id = trimmed[7..];
        else if (trimmed.StartsWith("http://") || trimmed.StartsWith("https://"))
        {
            var uri = new Uri(trimmed);
            if (uri.AbsolutePath.StartsWith("/match/"))
                id = uri.AbsolutePath[7..];
        }
        else if (trimmed.StartsWith("match/"))
            id = trimmed[6..];
        else if (trimmed.All(c => char.IsLetterOrDigit(c)))
            id = trimmed;
        else
            id = null;

        if (!string.IsNullOrEmpty(id) && id.All(char.IsLetterOrDigit))
        {
            NavManager.NavigateTo($"/match/{id}");
        }
        else
        {
            matchError = "Ogiltigt match-id eller länk.";
        }
    }

    private void HandleMatchInputKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GoToMatch();
        }
    }
}