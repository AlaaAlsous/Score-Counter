@page "/about"
@inject NavigationManager NavManager

    <PageTitle>Home</PageTitle>

<div class="home-hero">
    <h1>Score Counter</h1>
    <p>Keep track of scores — simple, fast, and stylish. Perfect for games, competitions, and after work.</p>
</div>

<div class="home-features">
    <div class="feature-card">
        <div class="icon">🎯</div>
        <h3>Create Match</h3>
        <p>Create a match in seconds. Choose players, starting score, and rules.</p>
    </div>
    <div class="feature-card">
        <div class="icon">👥</div>
        <h3>Invite</h3>
        <p>Share the match link with participants. Everyone sees the scores in real time.</p>
    </div>
    <div class="feature-card">
        <div class="icon">📊</div>
        <h3>Follow the Score</h3>
        <p>Update scores with one click. Custom score changes are supported.</p>
    </div>
    <div class="feature-card">
        <div class="icon">🏆</div>
        <h3>Crown the Winner</h3>
        <p>End the match and see the final results with the winner on top.</p>
    </div>
</div>