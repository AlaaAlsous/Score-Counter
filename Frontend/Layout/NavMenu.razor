@inject IJSRuntime JS

<div class="top-row">
    <a class="navbar-brand" href="">Score Counter</a>
    <button title="Menu" class="navbar-toggler" @onclick="ToggleNavMenu">
        ☰
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav>
        <div class="nav-item">
            <NavLink class="nav-link" href="/">
                🏠 Home
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="/match-enter">
                🎮 Go to Match
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="/about">
                ℹ️ About
            </NavLink>
        </div>
    </nav>
    <div class="theme-toggle-wrapper">
        <button title="Toggle theme" class="theme-toggle" @onclick="ToggleTheme">
            @(_isDark ? "☀️" : "🌙")
        </button>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool _isDark = false;

    private string? NavMenuCssClass => collapseNavMenu ? "nav-collapsed" : null;

    protected override async Task OnInitializedAsync()
    {
        var theme = await JS.InvokeAsync<string>("getCurrentTheme");
        _isDark = theme == "dark";
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task ToggleTheme()
    {
        await JS.InvokeVoidAsync("toggleTheme");
        _isDark = !_isDark;
    }
}
